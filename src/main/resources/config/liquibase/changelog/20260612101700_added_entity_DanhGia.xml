<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="20260612101700-1" author="codex">
        <createTable tableName="danhgia">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="so_sao" type="integer">
                <constraints nullable="false" />
            </column>
            <column name="noi_dung" type="nvarchar(max)">
                <constraints nullable="true" />
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <column name="phim_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <column name="nguoi_dung_id" type="bigint">
                <constraints nullable="false" />
            </column>
        </createTable>
        <dropDefaultValue tableName="danhgia" columnName="created_at" columnDataType="${datetimeType}"/>
    </changeSet>
</databaseChangeLog>
